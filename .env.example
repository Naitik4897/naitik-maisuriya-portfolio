# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ==================================================================
# EmailJS Configuration (REQUIRED for contact form)
# Get these from https://emailjs.com after creating an account
# Contact form sends to email (visible to users)
# ==================================================================

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# ==================================================================
# WhatsApp Configuration (Silent backup)
# Your WhatsApp number in international format (no + or spaces)
# Example: For +91 8485939130, use: 918485939130
# Used silently in background - users don't know about this
# ==================================================================

VITE_WHATSAPP_NUMBER=918485939130

# ==================================================================
# INSTRUCTIONS:
# ==================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Replace "your_*_here" with your actual EmailJS values
# 3. Keep .env.local private (already in .gitignore)
# 4. Restart dev server after making changes
#
# Contact form will send to BOTH email AND WhatsApp silently.
# Users only see "Send via Email" and only email is mentioned.
# Setup guide: https://emailjs.com
# ==================================================================

